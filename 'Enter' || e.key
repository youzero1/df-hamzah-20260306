' ') onToggle();
        }}
        aria-expanded={visible}
        aria-label="Toggle history panel"
      >
        <span style={{ fontWeight: 600, fontSize: '0.9rem' }}>
          📋 History ({history.length})
        </span>
        <span style={{ fontSize: '0.8rem', color: 'var(--color-text-muted)' }}>
          {visible ? '▲ Hide' : '▼ Show'}
        </span>
      </div>

      {visible && (
        <div style={{ padding: '0 16px 12px' }}>
          {history.length > 0 && (
            <button
              onClick={(e) => {
                e.stopPropagation();
                onClear();
              }}
              style={{
                width: '100%',
                padding: '8px',
                marginBottom: '8px',
                backgroundColor: 'rgba(233,69,96,0.15)',
                color: 'var(--color-primary)',
                borderRadius: '8px',
                fontSize: '0.8rem',
                fontWeight: 600,
                border: 'none',
                cursor: 'pointer',
              }}
              aria-label="Clear history"
            >
              🗑 Clear History
            </button>
          )}

          <div
            style={{
              maxHeight: '200px',
              overflowY: 'auto',
            }}
          >
            {history.length === 0 ? (
              <div
                style={{
                  textAlign: 'center',
                  color: 'var(--color-text-muted)',
                  padding: '20px',
                  fontSize: '0.85rem',
                }}
              >
                No calculations yet
              </div>
            ) : (
              history.map((item) => (
                <div
                  key={item.id}
                  style={{
                    padding: '8px 0',
                    borderBottom: '1px solid rgba(255,255,255,0.05)',
                    fontSize: '0.85rem',
                  }}
                >
                  <div style={{ color: 'var(--color-text-muted)', fontFamily: 'monospace' }}>
                    {item.expression}
                  </div>
                  <div style={{ fontWeight: 600, fontFamily: 'monospace' }}>
                    = {item.result}
                  </div>
                  <div
                    style={{
                      fontSize: '0.7rem',
                      color: 'var(--color-text-muted)',
                      marginTop: '2px',
                    }}
                  >
                    {item.type} • {new Date(item.createdAt).toLocaleTimeString()}
                  </div>
                </div>
              ))
            )}
          </div>
        </div>
      )}
    </div>
  );
}
</file>

<file path="df/src/components/Calculator.tsx">
'use client';
import React, { useState, useCallback, useEffect } from 'react';
import Button from './Button';
import Display from './Display';
import HistoryPanel from './HistoryPanel';
import {
  safeEvaluate,
  calculateDiscount,
  calculateTax,
  calculateMargin,
  calculateMarkup,
  formatNumber,
} from '../lib/calculator';
import type { CalculationRecord, CalculationType } from '../types';

type Mode = CalculationType;

const MODES: { label: string; value: Mode }[] = [
  { label: '🔢 Basic', value: 'basic' },
  { label: '💸 Discount', value: 'discount' },
  { label: '🏷 Tax', value: 'tax' },
  { label: '📊 Margin', value: 'margin' },
  { label: '📈 Markup', value: 'markup' },
];

export default function Calculator() {
  const [expression, setExpression] = useState('');
  const [result, setResult] = useState('');
  const [mode, setMode] = useState<Mode>('basic');
  const [history, setHistory] = useState<CalculationRecord[]>([]);
  const [historyVisible, setHistoryVisible] = useState(false);
  const [field1, setField1] = useState('');
  const [field2, setField2] = useState('');

  // Fetch history on mount
  useEffect(() => {
    fetchHistory();
  }, []);

  const fetchHistory = async () => {
    try {
      const res = await fetch('/api/calculations');
      if (res.ok) {
        const data = await res.json();
        setHistory(data);
      }
    } catch (err) {
      console.error('Failed to fetch history:', err);
    }
  };

  const saveCalculation = async (expr: string, res: string, type: CalculationType) => {
    try {
      const response = await fetch('/api/calculations', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ expression: expr, result: res, type }),
      });
      if (response.ok) {
        fetchHistory();
      }
    } catch (err) {
      console.error('Failed to save calculation:', err);
    }
  };

  const clearHistory = async () => {
    try {
      const res = await fetch('/api/calculations', { method: 'DELETE' });
      if (res.ok) {
        setHistory([]);
      }
    } catch (err) {
      console.error('Failed to clear history:', err);
    }
  };

  const appendToExpression = useCallback((value: string) => {
    setExpression((prev) => prev + value);
    setResult('');
  }, []);

  const clearAll = useCallback(() => {
    setExpression('');
    setResult('');
    setField1('');
    setField2('');
  }, []);

  const deleteLast = useCallback(() => {
    setExpression((prev) => prev.slice(0, -1));
  }, []);

  const evaluateBasic = useCallback(() => {
    if (!expression.trim()) return;
    try {
      const evalResult = safeEvaluate(expression);
      const formatted = formatNumber(evalResult);
      setResult(formatted);
      saveCalculation(expression, formatted, 'basic');
    } catch {
      setResult('Error');
    }
  }, [expression]);

  const evaluateSpecial = useCallback(() => {
    const val1 = parseFloat(field1);
    const val2 = parseFloat(field2);

    if (isNaN(val1) || isNaN(val2)) {
      setResult('Invalid input');
      return;
    }

    try {
      let expr = '';
      let res = '';

      switch (mode) {
        case 'discount': {
          const d = calculateDiscount(val1, val2);
          expr = `${val1} - ${val2}% discount`;
          res = `$${d.finalPrice} (saved $${d.discountAmount})`;
          break;
        }
        case 'tax': {
          const t = calculateTax(val1, val2);
          expr = `${val1} + ${val2}% tax`;
          res = `$${t.totalPrice} (tax: $${t.taxAmount})`;
          break;
        }
        case 'margin': {
          const m = calculateMargin(val1, val2);
          expr = `Cost: ${val1}, Sell: ${val2}`;
          res = `Profit: $${m.profit} (${m.marginPercent}% margin)`;
          break;
        }
        case 'markup': {
          const mk = calculateMarkup(val1, val2);
          expr = `${val1} + ${val2}% markup`;
          res = `$${mk.sellingPrice} (markup: $${mk.markupAmount})`;
          break;
        }
        default:
          return;
      }

      setExpression(expr);
      setResult(res);
      saveCalculation(expr, res, mode);
    } catch {
      setResult('Error');
    }
  }, [field1, field2, mode]);

  const handleModeChange = (newMode: Mode) => {
    setMode(newMode);
    clearAll();
  };

  const basicButtons = [
    { label: 'C', variant: 'clear' as const, onClick: clearAll },
    { label: '⌫', variant: 'action' as const, onClick: deleteLast },
    { label: '%', variant: 'action' as const, onClick: () => appendToExpression('%') },
    { label: '÷', variant: 'operator' as const, onClick: () => appendToExpression('/') },
    { label: '7', variant: 'default' as const, onClick: () => appendToExpression('7') },
    { label: '8', variant: 'default' as const, onClick: () => appendToExpression('8') },
    { label: '9', variant: 'default' as const, onClick: () => appendToExpression('9') },
    { label: '×', variant: 'operator' as const, onClick: () => appendToExpression('*') },
    { label: '4', variant: 'default' as const, onClick: () => appendToExpression('4') },
    { label: '5', variant: 'default' as const, onClick: () => appendToExpression('5') },
    { label: '6', variant: 'default' as const, onClick: () => appendToExpression('6') },
    { label: '-', variant: 'operator' as const, onClick: () => appendToExpression('-') },
    { label: '1', variant: 'default' as const, onClick: () => appendToExpression('1') },
    { label: '2', variant: 'default' as const, onClick: () => appendToExpression('2') },
    { label: '3', variant: 'default' as const, onClick: () => appendToExpression('3') },
    { label: '+', variant: 'operator' as const, onClick: () => appendToExpression('+') },
    { label: '0', variant: 'default' as const, onClick: () => appendToExpression('0'), wide: true },
    { label: '.', variant: 'default' as const, onClick: () => appendToExpression('.') },
    { label: '=', variant: 'equals' as const, onClick: evaluateBasic },
  ];

  const fieldLabels: Record<string, [string, string]> = {
    discount: ['Original Price ($)', 'Discount (%)'],
    tax: ['Price ($)', 'Tax Rate (%)'],
    margin: ['Cost Price ($)', 'Selling Price ($)'],
    markup: ['Cost Price ($)', 'Markup (%)'],
  };

  return (
    <div
      style={{
        width: '100%',
        maxWidth: '400px',
        backgroundColor: 'var(--bg-card)',
        borderRadius: '16px',
        padding: '20px',
        boxShadow: 'var(--shadow)',
        border: '1px solid rgba(255,255,255,0.05)',
      }}
    >
      {/* Mode Selector */}
      <div
        style={{
          display: 'flex',
          gap: '4px',
          marginBottom: '16px',
          overflowX: 'auto',
          paddingBottom: '4px',
        }}
      >
        {MODES.map((m) => (
          <button
            key={m.value}
            onClick={() => handleModeChange(m.value)}
            style={{
              padding: '8px 12px',
              borderRadius: '8px',
              fontSize: '0.75rem',
              fontWeight: 600,
              whiteSpace: 'nowrap',
              backgroundColor:
                mode === m.value ? 'var(--color-primary)' : 'rgba(255,255,255,0.05)',
              color: mode === m.value ? '#fff' : 'var(--color-text-muted)',
              border: 'none',
              cursor: 'pointer',
              transition: 'all 0.15s ease',
            }}
          >
            {m.label}
          </button>
        ))}
      </div>

      {/* Display */}
      <Display
        expression={expression}
        result={result}
        mode={mode === 'basic' ? 'Basic Calculator' : `${mode.charAt(0).toUpperCase() + mode.slice(1)} Calculator`}
      />

      {/* Basic Mode */}
      {mode === 'basic' && (
        <div
          style={{
            display: 'grid',
            gridTemplateColumns: 'repeat(4, 1fr)',
            gap: '8px',
          }}
        >
          {basicButtons.map((btn, i) => (
            <Button
              key={`${btn.label}-${i}`}
              label={btn.label}
              onClick={btn.onClick}
              variant={btn.variant}
              wide={btn.wide}
            />
          ))}
        </div>
      )}

      {/* Special Modes */}
      {mode !== 'basic' && fieldLabels[mode] && (
        <div style={{ display: 'flex', flexDirection: 'column', gap: '12px' }}>
          <div>
            <label
              style={{
                fontSize: '0.8rem',
                color: 'var(--color-text-muted)',
                marginBottom: '4px',
                display: 'block',
              }}
            >
              {fieldLabels[mode][0]}
            </label>
            <input
              type="number"
              value={field1}
              onChange={(e) => setField1(e.target.value)}
              placeholder="0.00"
              style={{
                width: '100%',
                padding: '12px',
                borderRadius: '8px',
                border: '1px solid rgba(255,255,255,0.1)',
                backgroundColor: 'var(--color-display-bg)',
                color: 'var(--color-text)',
                fontSize: '1.1rem',
                fontFamily: 'monospace',
                outline: 'none',
              }}
              data-testid="field1"
            />
          </div>
          <div>
            <label
              style={{
                fontSize: '0.8rem',
                color: 'var(--color-text-muted)',
                marginBottom: '4px',
                display: 'block',
              }}
            >
              {fieldLabels[mode][1]}
            </label>
            <input
              type="number"
              value={field2}
              onChange={(e) => setField2(e.target.value)}
              placeholder="0.00"
              style={{
                width: '100%',
                padding: '12px',
                borderRadius: '8px',
                border: '1px solid rgba(255,255,255,0.1)',
                backgroundColor: 'var(--color-display-bg)',
                color: 'var(--color-text)',
                fontSize: '1.1rem',
                fontFamily: 'monospace',
                outline: 'none',
              }}
              data-testid="field2"
            />
          </div>
          <div style={{ display: 'flex', gap: '8px' }}>
            <Button label="Clear" onClick={clearAll} variant="clear" />
            <div style={{ flex: 1 }}>
              <Button label="Calculate" onClick={evaluateSpecial} variant="equals" />
            </div>
          </div>
        </div>
      )}

      {/* History */}
      <HistoryPanel
        history={history}
        onClear={clearHistory}
        visible={historyVisible}
        onToggle={() => setHistoryVisible((v) => !v)}
      />
    </div>